# ── Railway booking API (bot.ts) ─────────────────────────────
# Set these in Railway → Variables (never commit real values)
BOT_TOKEN=your-telegram-bot-token
MASTER_CHAT_ID=your-telegram-numeric-chat-id
PORT=3000
ALLOWED_ORIGINS=https://gen-lang-client-0122413605.web.app,http://localhost:5173

# Railway volume: mount at /app/data in dashboard (see DEPLOY-RAILWAY.md)
# RAILWAY_VOLUME_MOUNT_PATH is set automatically by Railway
# DATA_FILE=/app/data/bookings.json

# Firebase build: set before `npm run build` so the site calls Railway
VITE_BOOKING_API_URL=https://your-service.up.railway.app

# ── Legacy server.ts (optional) ────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# The public URL of your app (used for Telegram webhooks)
# Example: https://your-app.web.app
APP_URL=https://your-app.web.app

# Firebase configuration is managed automatically in firebase-applet-config.json

# Firebase Admin (server-side, for saving bookings to Firestore)
# Optional for local dev: if unset, the server will skip Firestore persistence.
FIREBASE_PROJECT_ID=your-firebase-project-id
# Optional: used only if you plan to use Firebase Realtime Database from the server
FIREBASE_DATABASE_URL=https://your-firebase-project-id-default-rtdb.firebaseio.com
# Path to a Firebase service account JSON file (download from Firebase Console)
# Windows example: C:/path/to/serviceAccountKey.json
GOOGLE_APPLICATION_CREDENTIALS=

# Admin UI (client-side): comma-separated allowed Google emails
# Example: yourname@gmail.com,otheradmin@gmail.com
VITE_ADMIN_EMAILS=your-admin-email@example.com
