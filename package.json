{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "dev:api": "tsx bot.ts",
    "build": "vite build && npm run build:api",
    "build:api": "esbuild bot.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/api.cjs",
    "start": "node dist/api.cjs",
    "start:server": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "railway:setup": "powershell -ExecutionPolicy Bypass -File scripts/railway-setup.ps1",
    "assets:portfolio": "node scripts/convert-portfolio-assets.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.22.2",
    "firebase": "^12.13.0",
    "firebase-admin": "^13.10.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "node-telegram-bot-api": "^0.67.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.15.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.19",
    "@types/node-telegram-bot-api": "^0.64.14",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "heic-convert": "^2.1.0",
    "tailwindcss": "^4.1.14",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  },
